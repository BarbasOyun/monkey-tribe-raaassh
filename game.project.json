{
    "name": "monkey-tribe-raaassh",
    "tree": {
        "$className": "DataModel",
        "ReplicatedStorage": {
            "Shared": {
                "$path": "src/shared"
            },
            "Packages": {
                "$path": "Packages"
            }
        },
        "ServerScriptService": {
            "Server": {
                "$path": "src/game/server"
            }
        },
        "StarterPlayer": {
            "StarterPlayerScripts": {
                "Client": {
                    "$path": "src/game/client"
                }
            }
        },
        "Workspace": {
            "$properties": {
                "FilteringEnabled": true
            }
        },
        "SoundService": {
            "$properties": {
                "RespectFilteringEnabled": true
            }
        }
    }
}